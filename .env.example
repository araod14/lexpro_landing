# ============================================================================
# Configuración SMTP para el formulario de postulaciones (sección Empleo).
# Copia este archivo a .env.local (ignorado por git) y rellena los valores
# reales del servidor de correo de lexprosoluciones.com.
# ============================================================================

SMTP_HOST=mail.lexprosoluciones.com
SMTP_PORT=587
SMTP_USER=no-reply@lexprosoluciones.com
SMTP_PASS=tu-contraseña-smtp
# Remitente que verá el destinatario. Si se omite, se usa SMTP_USER.
SMTP_FROM=Lexpro Postulaciones <no-reply@lexprosoluciones.com>
